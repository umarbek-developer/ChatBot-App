# Copy to .env (in this src/ directory) and fill in. Values below are dev-safe
# defaults; the "# PROD:" notes show what to change for a server deployment.

# ===== MAIN SETTINGS =====
DEBUG=1
# PROD: DEBUG=0  -> loads config.settings.production (ALLOWED_HOSTS from env, etc.)
SECRET_KEY=test
# PROD: long random string, e.g. `python -c "import secrets;print(secrets.token_urlsafe(64))"`
ALLOWED_HOSTS=127.0.0.1,localhost
# PROD: yourdomain.com,www.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=https://localhost:3000
# PROD: https://yourdomain.com
BASE_URL_LINK=http://127.0.0.1:8000/api/v1/user/auth/register/confirmations/
# PROD (after TLS/certbot works): SECURE_SSL=1 enables HTTPS redirect, secure
# cookies and HSTS. Leave unset for the first plain-HTTP bring-up.
SECURE_SSL=

# ===== DATABASE =====
DB_TYPE=sqlite3
# PROD: DB_TYPE=psql  (then fill NAME/USER/PASSWORD below)
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# ===== CELERY =====
# Leave blank to use local Redis db 0 (auto-built with REDIS_* below).
# Set explicitly for a remote / passworded broker, e.g.
#   redis://:password@127.0.0.1:6379/0
BASE_URL=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ===== TELEGRAM BOT =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=
TELEGRAM_CHANNEL_ID=

# ===== REDIS =====  (required: Celery + Channels + realtime presence)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== Email =====
# Gmail address used as the SMTP sender
EMAIL_HOST=
# Gmail App Password (Google Account → Security → App passwords) — NOT your login password
EMAIL_PASSWORD=
